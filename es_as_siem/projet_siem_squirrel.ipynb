    "# Création de features dérivées avancées\n",
    "\n",
    "# Taille moyenne des paquets envoyés au serveur\n",
    "df[\"avg_pkt_size_toserver\"] = df[\"bytes_toserver\"] / (df[\"pkts_toserver\"] + 1)\n",
    "\n",
    "# Taille moyenne des paquets envoyés au client\n",
    "df[\"avg_pkt_size_toclient\"] = df[\"bytes_toclient\"] / (df[\"pkts_toclient\"] + 1)\n",
    "\n",
    "# Ratio paquets client/serveur\n",
    "df[\"pkt_ratio\"] = df[\"pkts_toserver\"] / (df[\"pkts_toclient\"] + 1)\n",
    "\n",
    "# Ratio bytes client/serveur\n",
    "df[\"byte_ratio\"] = df[\"bytes_toserver\"] / (df[\"bytes_toclient\"] + 1)\n",
    "\n",
    "print(f\"✓ Dataset créé : {len(df)} lignes\")\n",
    "\n",
    "\n",
    "print(\"\\nEXPLICATION DES VARIABLES :\")\n",
    "print(\"--------------------------------------------------\")\n",
    "print(\"pkts_toserver      → Nombre de paquets envoyés vers le serveur\")\n",
    "print(\"pkts_toclient      → Nombre de paquets envoyés vers le client\")\n",
    "print(\"bytes_toserver     → Volume total de données envoyées vers serveur\")\n",
    "print(\"bytes_toclient     → Volume total de données envoyées vers client\")\n",
    "print(\"total_pkts         → Total des paquets échangés\")\n",
    "print(\"total_bytes        → Total des bytes échangés\")\n",
    "print(\"src_port           → Port d'origine\")\n",
    "print(\"dest_port          → Port destination (ex: 80 HTTP, 443 HTTPS, 8080 etc.)\")\n",
    "print(\"proto              → Protocole (6=TCP, 17=UDP)\")\n",
    "print(\"is_anomaly         → 0 = trafic normal | 1 = anomalie détectée\")\n",
    "print(\"attack_type        → Signature de l'attaque détectée\")\n",
    "\n",
    "\n",
    "# Statistiques exploratoires\n",
    "\n",
    "print(\"---------------------------------------------------\\nStatistiques du dataset...\")\n",
    "\n",
    "print(f\"\\nRépartition des classes :\")\n",
    "print(df[\"is_anomaly\"].value_counts())\n",
    "\n",
    "# Calcul du pourcentage de classes\n",
