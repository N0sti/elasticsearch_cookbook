    "═══════════════════════════════════════════════════════\n",
    "ATTAQUE - BRUTE FORCE\n",
    "═══════════════════════════════════════════════════════\n",
    "Envoie 8 requêtes avec \"pass=\" dans l'URI en moins de 10 secondes\n",
    "\"\"\"\n",
    "\n",
    "import subprocess  # Permet d'exécuter des commandes système (docker, curl, etc.)\n",
    "import time        # Permet de gérer les pauses et mesurer la durée totale\n",
    "\n",
    "# En tête\n",
    "\n",
    "print(\"🔐 ATTAQUE 3 : BRUTE FORCE\")  # Titre de l'attaque\n",
    "print(\"=\" * 60)\n",
    "print(\"\\n📋 Objectif : Déclencher 'BRUTE FORCE DETECTED'\")\n",
    "print(\"   Règle : 6 requêtes avec 'pass=' dans l'URI en 10 secondes\\n\")\n",
    "# L'objectif est de dépasser le seuil défini dans une règle Suricata :\n",
    "# au moins 6 requêtes contenant \"pass=\" dans l'URI en moins de 10 secondes.\n",
    "\n",
    "# Liste de mots de passe à tester\n",
    "\n",
    "# Liste simulant un dictionnaire de mots de passe courants\n",
    "passwords = [\n",
    "    \"admin\",\n",
    "    \"password\",\n",
    "    \"123456\",\n",
    "    \"qwerty\",\n",
    "    \"letmein\",\n",
    "    \"admin123\",\n",
    "    \"root\",\n",
    "    \"toor\"\n",
    "]\n",
    "\n",
    "print(f\"  Tentatives de connexion avec {len(passwords)} mots de passe...\\n\")\n",
    "\n",
    "# Enregistre l'heure de début pour mesurer la durée totale\n",
    "start = time.time()\n",
    "\n",
    "# Envois de requêtte de brute force\n",
    "\n",
    "# enumerate permet d'avoir l'index (i) et le mot de passe (pwd)\n",
    "for i, pwd in enumerate(passwords, 1):\n",
    "\n",
    "    # La chaîne \"pass=\" doit apparaître dans l'URI\n",
    "    # car la règle IDS détecte cette signature spécifique.\n",
    "    url = f\"http://example.com/login?user=admin&pass={pwd}\"\n",
    "    \n",
    "    # Exécute la requête HTTP depuis le container \"suricata\"\n",
    "    # docker exec suricata : lance la commande dans le container\n",
    "    # curl -s : mode silencieux (pas d'affichage du contenu)\n",
    "    subprocess.run(\n",
    "        f'docker exec suricata curl -s \"{url}\"',\n",
    "        shell=True,          # Utilise le shell pour interpréter la commande complète\n",
    "        capture_output=True, # Capture la sortie sans l'afficher\n",
    "        timeout=2            # Timeout de sécurité (2 secondes max)\n",
    "    )\n",
    "    \n",
    "    # Affiche la progression\n",
    "    print(f\"  [{i}/8] Tentative avec pass={pwd}\")\n",
    "\n",
    "    # Pause de 0.8 seconde entre chaque tentative\n",
    "    # 8 requêtes espacées de 0.8s ≈ 6.4 secondes total\n",
    "    # Ce qui reste en dessous du seuil de 10 secondes\n",
    "    time.sleep(0.8)\n",
    "\n",
    "# Statistique finale\n",
    "\n",
    "# Calcul de la durée totale de l'attaque\n",
    "duration = time.time() - start\n",
    "\n",
    "print(f\"\\n✅ {len(passwords)} tentatives avec 'pass=' dans l'URI\")\n",
    "print(f\"   Durée : {duration:.1f} secondes\")\n",
    "print(f\"   Seuil : 6 requêtes en 10s → {len(passwords)} en {duration:.1f}s\")\n",
    "print(f\"\\n⚠️  Devrait déclencher : BRUTE FORCE DETECTED\")"
