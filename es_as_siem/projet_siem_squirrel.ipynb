    "def simulate_port_scan(src_ip=\"192.168.99.1\", num_events=150):\n",
    "    \"\"\"\n",
    "    Simule un scan de ports : une même IP source contacte de nombreuses\n",
    "    destinations sur des ports variés en très peu de temps.\n",
    "    Suricata signerait ces événements comme 'ET SCAN'.\n",
    "    \"\"\"\n",
    "    index = get_or_create_index()\n",
    "    now = datetime.now(timezone.utc)\n",
    "    docs = []\n",
