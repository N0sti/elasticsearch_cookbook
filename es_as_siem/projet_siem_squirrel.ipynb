    "\"\"\"\n",
    "═══════════════════════════════════════════════════════════\n",
    "CLASSIFIEUR BINAIRE SUPERVISÉ\n",
    "Apprentissage supervisé : normal (0) vs anomalie (1)\n",
    "Modèle : Random Forest (ensemble d'arbres de décision)\n",
    "═══════════════════════════════════════════════════════════\n",
    "\"\"\"\n",
    "\n",
    "# --- Imports ---\n",
    "# Manipulation des données\n",
    "import json\n",
    "import subprocess\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# Modèles et outils scikit-learn\n",
    "from sklearn.ensemble import RandomForestClassifier   # Modèle supervisé\n",
    "from sklearn.tree import DecisionTreeClassifier       # Arbre de décision simple\n",
    "from sklearn.model_selection import train_test_split  # Découpage train/test\n",
    "from sklearn.model_selection import cross_val_score   # Validation croisée\n",
    "from sklearn.preprocessing import StandardScaler      # Normalisation\n",
    "from sklearn.metrics import (\n",
    "    classification_report,   # Rapport précision/rappel/F1\n",
    "    confusion_matrix,        # Matrice de confusion\n",
    "    accuracy_score           # Exactitude globale\n",
    ")\n",
    "\n",
    "print(\"CLASSIFIEUR BINAIRE SUPERVISÉ\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "# ════════════════════════════════════════════════════════════\n",
    "# ÉTAPE 1 : CHARGEMENT ET LABELLISATION DES DONNÉES\n",
    "# ════════════════════════════════════════════════════════════\n",
    "\n",
    "print(\"\\n[1] Chargement des logs depuis eve.json...\")\n",
    "\n",
    "result = subprocess.run(\n",
    "    [\"docker\", \"exec\", \"suricata\", \"cat\", \"/var/log/suricata/eve.json\"],\n",
    "    capture_output=True,\n",
    "    text=True\n",
    ")\n",
    "\n",
    "logs = []\n",
    "for line in result.stdout.splitlines():\n",
    "    try:\n",
    "        logs.append(json.loads(line))\n",
    "    except:\n",
    "        pass\n",
    "\n",
    "print(f\"✓ {len(logs)} événements chargés\")\n",
    "\n",
    "# Séparer flows et alertes\n",
    "flows  = [l for l in logs if l.get(\"event_type\") == \"flow\"]\n",
    "alerts = [l for l in logs if l.get(\"event_type\") == \"alert\"]\n",
    "\n",
    "print(f\"✓ {len(flows)} flows réseau\")\n",
    "print(f\"✓ {len(alerts)} alertes Suricata\")\n",
    "\n",
    "# ════════════════════════════════════════════════════════════\n",
    "# ÉTAPE 2 : CONSTRUCTION DU CORPUS D'ENTRAÎNEMENT\n",
    "# Chaque flow réseau devient un exemple (ligne) du corpus.\n",
    "# Le label is_anomaly indique si ce flow a déclenché une alerte.\n",
    "# ════════════════════════════════════════════════════════════\n",
    "\n",
    "print(\"\\n[2] Construction du corpus d'entraînement...\")\n",
    "\n",
    "# Index des alertes par flow_id pour accélerer la recherche\n",
    "alert_index = {}\n",
    "for alert in alerts:\n",
    "    fid = alert.get(\"flow_id\")\n",
    "    if fid and fid not in alert_index:\n",
    "        alert_index[fid] = alert.get(\"alert\", {}).get(\"signature\", \"unknown\")\n",
    "\n",
    "data = []\n",
    "\n",
    "for flow in flows:\n",
    "    fd       = flow.get(\"flow\", {})\n",
    "    flow_id  = flow.get(\"flow_id\")\n",
    "\n",
    "    pkts_srv = fd.get(\"pkts_toserver\", 0)\n",
    "    pkts_cli = fd.get(\"pkts_toclient\", 0)\n",
    "    byt_srv  = fd.get(\"bytes_toserver\", 0)\n",
    "    byt_cli  = fd.get(\"bytes_toclient\", 0)\n",
    "\n",
    "    # --- Variables (features) extraites du flow ---\n",
    "    row = {\n",
    "        # Variables brutes\n",
    "        \"pkts_toserver\":  pkts_srv,\n",
    "        \"pkts_toclient\":  pkts_cli,\n",
    "        \"bytes_toserver\": byt_srv,\n",
    "        \"bytes_toclient\": byt_cli,\n",
    "\n",
    "        # Variables dérivées — totaux\n",
    "        \"total_pkts\":  pkts_srv + pkts_cli,\n",
    "        \"total_bytes\": byt_srv  + byt_cli,\n",
    "\n",
    "        # Variables réseau\n",
    "        \"src_port\":  flow.get(\"src_port\", 0),\n",
    "        \"dest_port\": flow.get(\"dest_port\", 0),\n",
    "        \"proto\": 6 if flow.get(\"proto\") == \"TCP\" else\n",
    "                 17 if flow.get(\"proto\") == \"UDP\" else 0,\n",
    "\n",
    "        # Variables dérivées — taille moyenne des paquets\n",
    "        \"avg_pkt_size_toserver\": byt_srv  / (pkts_srv + 1),\n",
    "        \"avg_pkt_size_toclient\": byt_cli  / (pkts_cli + 1),\n",
    "\n",
    "        # Variables dérivées — ratios\n",
    "        \"pkt_ratio\":  pkts_srv / (pkts_cli + 1),\n",
    "        \"byte_ratio\": byt_srv  / (byt_cli  + 1),\n",
    "\n",
    "        # ─── LABEL (étiquette supervisée) ───\n",
    "        # 0 = trafic normal\n",
    "        # 1 = anomalie (flow ayant déclenché une alerte Suricata)\n",
    "        \"is_anomaly\": 1 if flow_id in alert_index else 0,\n",
    "    }\n",
    "\n",
    "    data.append(row)\n",
    "\n",
    "df_sup = pd.DataFrame(data)\n",
    "df_sup = df_sup.replace([np.inf, -np.inf], np.nan).fillna(0)\n",
    "\n",
    "n_normal   = (df_sup[\"is_anomaly\"] == 0).sum()\n",
    "n_anomalie = (df_sup[\"is_anomaly\"] == 1).sum()\n",
    "\n",
    "print(f\"✓ Corpus créé : {len(df_sup)} exemples\")\n",
    "print(f\"   Normal   : {n_normal}  ({n_normal/len(df_sup)*100:.1f}%)\")\n",
    "print(f\"   Anomalie : {n_anomalie} ({n_anomalie/len(df_sup)*100:.1f}%)\")\n",
    "\n",
    "# ════════════════════════════════════════════════════════════\n",
    "# ÉTAPE 3 : DÉCOUPAGE TRAIN / TEST\n",
    "# On sépare le corpus en 70% entraînement et 30% test.\n",
    "# stratify=y garantit la même proportion de classes dans\n",
    "# chaque partie (important si le corpus est déséquilibré).\n",
    "# ════════════════════════════════════════════════════════════\n",
    "\n",
    "print(\"\\n[3] Découpage train/test (70% / 30%)...\")\n",
    "\n",
    "feature_columns = [\n",
    "    \"pkts_toserver\", \"pkts_toclient\",\n",
    "    \"bytes_toserver\", \"bytes_toclient\",\n",
    "    \"total_pkts\", \"total_bytes\",\n",
    "    \"src_port\", \"dest_port\", \"proto\",\n",
    "    \"avg_pkt_size_toserver\", \"avg_pkt_size_toclient\",\n",
    "    \"pkt_ratio\", \"byte_ratio\"\n",
    "]\n",
    "\n",
    "X = df_sup[feature_columns].copy()\n",
    "y = df_sup[\"is_anomaly\"].copy()\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y,\n",
    "    test_size=0.30,   # 30% pour le test\n",
    "    random_state=42,  # reproductibilité\n",
    "    stratify=y        # proportions conservées\n",
    ")\n",
    "\n",
    "print(f\"✓ Entraînement : {len(X_train)} exemples\")\n",
    "print(f\"   Normal: {(y_train==0).sum()}  |  Anomalie: {(y_train==1).sum()}\")\n",
    "print(f\"✓ Test       : {len(X_test)} exemples\")\n",
    "print(f\"   Normal: {(y_test==0).sum()}  |  Anomalie: {(y_test==1).sum()}\")\n",
    "\n",
    "# ════════════════════════════════════════════════════════════\n",
    "# ÉTAPE 4 : NORMALISATION\n",
    "# On centre et réduit les variables (moyenne=0, écart-type=1).\n",
    "# Le StandardScaler est APPRIS sur le train set uniquement,\n",
    "# puis APPLIQUÉ sur le test set — pour éviter toute fuite\n",
    "# d'information (data leakage).\n",
    "# ════════════════════════════════════════════════════════════\n",
    "\n",
    "print(\"\\n[4] Normalisation des variables (StandardScaler)...\")\n",
    "\n",
    "scaler = StandardScaler()\n",
    "X_train_s = scaler.fit_transform(X_train)   # apprend ET transforme\n",
    "X_test_s  = scaler.transform(X_test)        # transforme seulement\n",
    "\n",
    "print(\"✓ Variables normalisées (mean=0, std=1)\")\n",
    "\n",
    "# ════════════════════════════════════════════════════════════\n",
    "# ÉTAPE 5 : ENTRAÎNEMENT DU MODÈLE SUPERVISÉ\n",
    "# On entraîne deux modèles :\n",
    "#   - DecisionTreeClassifier  : arbre de décision simple (interprétable)\n",
    "#   - RandomForestClassifier  : ensemble d'arbres (plus robuste)\n",
    "# L'apprentissage se fait sur (X_train_s, y_train) :\n",
    "# le modèle ajuste ses paramètres internes pour minimiser\n",
    "# l'erreur sur le corpus d'entraînement.\n",
    "# class_weight='balanced' corrige le déséquilibre des classes.\n",
    "# ════════════════════════════════════════════════════════════\n",
    "\n",
    "print(\"\\n[5] Entraînement des modèles supervisés...\")\n",
    "\n",
    "# --- Modèle 1 : Arbre de décision ---\n",
    "dt = DecisionTreeClassifier(\n",
    "    max_depth=10,            # Profondeur max de l'arbre\n",
    "    class_weight=\"balanced\", # Corrige le déséquilibre des classes\n",
    "    random_state=42\n",
    ")\n",
    "dt.fit(X_train_s, y_train)\n",
    "print(\"✓ Arbre de décision entraîné\")\n",
    "\n",
    "# --- Modèle 2 : Random Forest (ensemble d'arbres) ---\n",
    "rf = RandomForestClassifier(\n",
    "    n_estimators=100,        # Nombre d'arbres dans la forêt\n",
    "    max_depth=10,            # Profondeur max par arbre\n",
    "    class_weight=\"balanced\", # Corrige le déséquilibre des classes\n",
    "    random_state=42,\n",
    "    n_jobs=-1                # Utilise tous les cœurs CPU\n",
    ")\n",
    "rf.fit(X_train_s, y_train)\n",
    "print(f\"✓ Random Forest entraîné ({rf.n_estimators} arbres)\")\n",
    "\n",
    "# ════════════════════════════════════════════════════════════\n",
    "# ÉTAPE 6 : ÉVALUATION DES PERFORMANCES\n",
    "# On évalue sur le TEST SET (données jamais vues pendant\n",
    "# l'entraînement) pour mesurer la capacité de généralisation.\n",
    "# ════════════════════════════════════════════════════════════\n",
    "\n",
    "print(\"\\n[6] Évaluation des performances sur le test set...\")\n",
    "\n",
    "for nom, modele in [(\"Arbre de décision\", dt), (\"Random Forest\", rf)]:\n",
    "\n",
    "    y_pred = modele.predict(X_test_s)\n",
    "\n",
    "    acc = accuracy_score(y_test, y_pred)\n",
    "    cm  = confusion_matrix(y_test, y_pred)\n",
    "    tn, fp, fn, tp = cm.ravel() if cm.size == 4 else (0, 0, 0, 0)\n",
    "\n",
    "    precision = tp / (tp + fp) if (tp + fp) > 0 else 0\n",
    "    rappel    = tp / (tp + fn) if (tp + fn) > 0 else 0\n",
    "    f1        = (2 * precision * rappel / (precision + rappel)\n",
    "                 if (precision + rappel) > 0 else 0)\n",
    "\n",
    "    print(f\"\\n{'='*55}\")\n",
    "    print(f\"  MODÈLE : {nom}\")\n",
    "    print(f\"{'='*55}\")\n",
    "    print(f\"  Accuracy  : {acc:.3f} ({acc*100:.1f}%)\")\n",
    "    print(f\"  Précision : {precision:.3f}  — qualité des alertes émises\")\n",
    "    print(f\"  Rappel    : {rappel:.3f}  — attaques réellement détectées\")\n",
    "    print(f\"  F1-score  : {f1:.3f}  — compromis précision/rappel\")\n",
    "    print(f\"\\n  Matrice de confusion :\")\n",
    "    print(f\"  ┌─────────────────────────────────────────┐\")\n",
    "    print(f\"  │               Prédit Normal  Prédit Anomalie │\")\n",
    "    print(f\"  │ Vrai Normal      {tn:8d}      {fp:12d}   │\")\n",
    "    print(f\"  │ Vrai Anomalie    {fn:8d}      {tp:12d}   │\")\n",
    "    print(f\"  └─────────────────────────────────────────┘\")\n",
    "    print(f\"  VP={tp}  VN={tn}  FP={fp}  FN={fn}\")\n",
    "    print(f\"\\n  Rapport détaillé :\")\n",
    "    print(classification_report(\n",
    "        y_test, y_pred,\n",
    "        target_names=[\"Normal\", \"Anomalie\"],\n",
    "        zero_division=0\n",
    "    ))\n",
    "\n",
    "# ════════════════════════════════════════════════════════════\n",
    "# ÉTAPE 7 : VALIDATION CROISÉE (k-fold)\n",
    "# On répète l'évaluation sur k=5 découpages différents pour\n",
    "# obtenir une estimation robuste des performances réelles.\n",
    "# ════════════════════════════════════════════════════════════\n",
    "\n",
    "print(\"\\n[7] Validation croisée (5-fold) sur le Random Forest...\")\n",
    "print(\"    (On ré-entraîne sur chaque fold pour estimer la robustesse)\\n\")\n",
    "\n",
    "X_all_s = scaler.fit_transform(X)   # normalise tout le corpus\n",
    "\n",
    "cv_scores = cross_val_score(\n",
    "    RandomForestClassifier(\n",
    "        n_estimators=100,\n",
    "        max_depth=10,\n",
    "        class_weight=\"balanced\",\n",
    "        random_state=42,\n",
    "        n_jobs=-1\n",
    "    ),\n",
    "    X_all_s, y,\n",
    "    cv=5,               # 5 folds\n",
    "    scoring=\"f1\"        # on optimise le F1-score (équilibre précision/rappel)\n",
    ")\n",
    "\n",
    "print(f\"  Scores F1 par fold : {[f'{s:.3f}' for s in cv_scores]}\")\n",
    "print(f\"  F1 moyen  : {cv_scores.mean():.3f}\")\n",
    "print(f\"  Écart-type: {cv_scores.std():.3f}  (faible = modèle stable)\")\n",
    "\n",
    "# ════════════════════════════════════════════════════════════\n",
    "# ÉTAPE 8 : IMPORTANCE DES VARIABLES\n",
    "# Le Random Forest indique quelles variables contribuent le\n",
    "# plus à la décision (classification).\n",
    "# ════════════════════════════════════════════════════════════\n",
    "\n",
    "print(\"\\n[8] Variables les plus importantes pour la décision :\")\n",
    "print(\"-\" * 45)\n",
    "\n",
    "importances = pd.Series(\n",
    "    rf.feature_importances_,\n",
    "    index=feature_columns\n",
    ").sort_values(ascending=False)\n",
    "\n",
    "for feature, score in importances.items():\n",
    "    bar = \"█\" * int(score * 50)\n",
    "    print(f\"  {feature:30s}  {score:.3f}  {bar}\")\n",
    "\n",
    "# ════════════════════════════════════════════════════════════\n",
    "# ÉTAPE 9 : PRÉDICTION SUR UN NOUVEAU FLOW\n",
    "# Simulation d'une prédiction en conditions réelles.\n",
    "# ════════════════════════════════════════════════════════════\n",
    "\n",
    "print(\"\\n[9] Prédiction sur de nouveaux flows réseau...\")\n",
    "print(\"-\" * 45)\n",
    "\n",
    "nouveaux_flows = pd.DataFrame([\n",
    "    {   # Flow normal : navigation HTTP classique\n",
    "        \"pkts_toserver\": 4, \"pkts_toclient\": 4,\n",
    "        \"bytes_toserver\": 350, \"bytes_toclient\": 900,\n",
    "        \"total_pkts\": 8, \"total_bytes\": 1250,\n",
    "        \"src_port\": 54321, \"dest_port\": 80, \"proto\": 6,\n",
    "        \"avg_pkt_size_toserver\": 87.5, \"avg_pkt_size_toclient\": 180.0,\n",
    "        \"pkt_ratio\": 0.8, \"byte_ratio\": 0.39,\n",
    "        \"description\": \"Navigation HTTP normale\"\n",
    "    },\n",
    "    {   # Port scan : beaucoup de SYN, aucune réponse\n",
    "        \"pkts_toserver\": 200, \"pkts_toclient\": 0,\n",
    "        \"bytes_toserver\": 11600, \"bytes_toclient\": 0,\n",
    "        \"total_pkts\": 200, \"total_bytes\": 11600,\n",
    "        \"src_port\": 53210, \"dest_port\": 22, \"proto\": 6,\n",
    "        \"avg_pkt_size_toserver\": 57.7, \"avg_pkt_size_toclient\": 0.0,\n",
    "        \"pkt_ratio\": 200.0, \"byte_ratio\": 11600.0,\n",
    "        \"description\": \"Port scan (SYN sans réponse)\"\n",
    "    },\n",
    "    {   # HTTP burst : rafale de requêtes en peu de temps\n",
    "        \"pkts_toserver\": 60, \"pkts_toclient\": 5,\n",
    "        \"bytes_toserver\": 4800, \"bytes_toclient\": 200,\n",
    "        \"total_pkts\": 65, \"total_bytes\": 5000,\n",
    "        \"src_port\": 41000, \"dest_port\": 8080, \"proto\": 6,\n",
    "        \"avg_pkt_size_toserver\": 78.7, \"avg_pkt_size_toclient\": 33.3,\n",
    "        \"pkt_ratio\": 10.0, \"byte_ratio\": 24.0,\n",
    "        \"description\": \"HTTP Burst (rafale de requêtes)\"\n",
    "    },\n",
    "    {   # Brute force : nombreuses petites requêtes avec pass=\n",
    "        \"pkts_toserver\": 16, \"pkts_toclient\": 8,\n",
    "        \"bytes_toserver\": 1280, \"bytes_toclient\": 480,\n",
    "        \"total_pkts\": 24, \"total_bytes\": 1760,\n",
    "        \"src_port\": 60000, \"dest_port\": 80, \"proto\": 6,\n",
    "        \"avg_pkt_size_toserver\": 76.5, \"avg_pkt_size_toclient\": 53.3,\n",
    "        \"pkt_ratio\": 1.78, \"byte_ratio\": 2.56,\n",
    "        \"description\": \"Brute Force (tentatives pass=)\"\n",
    "    },\n",
    "])\n",
    "\n",
    "X_new = nouveaux_flows[feature_columns]\n",
    "X_new_s = scaler.transform(X_new)\n",
    "\n",
    "predictions  = rf.predict(X_new_s)\n",
    "probabilites = rf.predict_proba(X_new_s)  # [P(normal), P(anomalie)]\n",
    "\n",
    "print(f\"  {'Description':<35} {'Prédiction':<15} {'Confiance'}\")\n",
    "print(f\"  {'-'*65}\")\n",
    "for i, row in nouveaux_flows.iterrows():\n",
    "    label      = \"🔴 ANOMALIE\" if predictions[i] == 1 else \"🟢 NORMAL\"\n",
    "    confiance  = probabilites[i][predictions[i]]\n",
    "    print(f\"  {row['description']:<35} {label:<20} {confiance*100:.1f}%\")\n",
    "\n",
    "print(\"\\n✅ Modèle supervisé entraîné et prêt à l'emploi.\")\n"
   ]
  },
