    "def simulate_http_burst(src_ip=\"192.168.99.2\", num_requests=300, window_seconds=30):\n",
    "    \"\"\"\n",
    "    Simule un burst HTTP / flood applicatif : des centaines de requêtes\n",
    "    arrivant depuis la même IP en quelques secondes (DoS bas débit).\n",
    "    \"\"\"\n",
    "    index = get_or_create_index()\n",
    "    now = datetime.now(timezone.utc)\n",
    "    docs = []\n",
    "    target_urls = [\"/\", \"/login\", \"/api/users\", \"/admin\", \"/wp-admin\", \"/index.php\"]\n",
    "    methods = [\"GET\", \"POST\", \"GET\", \"GET\", \"POST\", \"HEAD\"]\n",
    "\n",
    "    for i in range(num_requests):\n",
    "        ts = now - timedelta(seconds=random.uniform(0, window_seconds))\n",
    "        docs.append({\n",
    "            \"@timestamp\": ts.isoformat(),\n",
    "            \"event_type\": \"http\",\n",
    "            \"src_ip\": src_ip,\n",
    "            \"src_port\": random.randint(30000, 60000),\n",
    "            \"dest_ip\": \"10.0.0.10\",\n",
    "            \"dest_port\": 80,\n",
    "            \"proto\": \"TCP\",\n",
    "            \"http\": {\n",
    "                \"method\": random.choice(methods),\n",
    "                \"url\": random.choice(target_urls),\n",
    "                \"status\": random.choice([200, 403, 404, 500]),\n",
    "                \"length\": random.randint(100, 5000),\n",
    "            },\n",
    "            \"alert\": {\n",
    "                \"signature_id\": 2019284,\n",
    "                \"signature\": \"ET DOS HTTP Flood Detected\",\n",
    "                \"category\": \"Attempted Denial of Service\",\n",
    "                \"severity\": 1,\n",
    "            },\n",
    "            \"simulation\": True,\n",
    "        })\n",
    "\n",
    "    helpers.bulk(es, [{\"_op_type\": \"create\", \"_index\": index, \"_source\": d} for d in docs])\n",
