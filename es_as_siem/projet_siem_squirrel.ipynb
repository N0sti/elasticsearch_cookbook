   "source": [
    "\"\"\"\n",
    "═══════════════════════════════════════════════════════════\n",
    "CELLULE 1 : EXTRACTION ET PRÉPARATION DES DONNÉES\n",
    "═══════════════════════════════════════════════════════════\n",
    "\"\"\"\n",
    "\n",
    "# Bibliothèques nécessaires :\n",
    "# json → parser les lignes JSON du fichier eve.json\n",
    "# subprocess → exécuter une commande système (docker exec)\n",
    "# pandas → manipulation du dataset\n",
    "# numpy → opérations numériques\n",
    "import json\n",
    "import subprocess\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "print(\"EXTRACTION DES DONNÉES DEPUIS EVE.JSON\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "# Charger les logs depuis Suricata (dans le container Docker)\n",
    "\n",
    "print(\"\\n[1] Chargement des logs...\")\n",
    "\n",
    "# Exécute la commande :\n",
    "# docker exec suricata cat /var/log/suricata/eve.json\n",
    "# → récupère tout le contenu du fichier eve.json\n",
    "result = subprocess.run(\n",
    "    [\"docker\", \"exec\", \"suricata\", \"cat\", \"/var/log/suricata/eve.json\"],\n",
    "    capture_output=True,  # capture la sortie\n",
    "    text=True             # retourne la sortie en string\n",
    ")\n",
    "\n",
    "logs = []\n",
    "\n",
    "# Lecture ligne par ligne (chaque ligne = un JSON indépendant)\n",
    "for line in result.stdout.splitlines():\n",
    "    try:\n",
    "        # Conversion de la ligne texte en dictionnaire Python\n",
    "        logs.append(json.loads(line))\n",
    "    except:\n",
    "        # Ignore les lignes mal formées (robustesse)\n",
    "        pass\n",
    "\n",
    "print(f\"✓ {len(logs)} événements chargés\")\n",
    "\n",
    "# Filtrer les événements pertinents\n",
    "\n",
    "print(\"\\n[2] Filtrage des événements...\")\n",
    "\n",
    "# Séparer les types d'événements :\n",
    "# flow → statistiques réseau\n",
    "# alert → alertes déclenchées par les règles Suricata\n",
    "flows = [log for log in logs if log.get(\"event_type\") == \"flow\"]\n",
    "alerts = [log for log in logs if log.get(\"event_type\") == \"alert\"]\n",
    "\n",
    "print(f\"✓ {len(flows)} flows\")\n",
    "print(f\"✓ {len(alerts)} alertes\")\n",
    "\n",
    "# Construction du dataset Machine Learning\n",
    "\n",
    "print(\"\\n[3] Construction du dataset...\")\n",
    "\n",
    "data = []  # Liste qui contiendra toutes les lignes du dataset\n",
    "\n",
    "# Traitement de chaque flow réseau\n",
    "for flow in flows:\n",
    "    \n",
    "    # Récupère les métriques réseau internes\n",
    "    flow_data = flow.get(\"flow\", {})\n",
    "    \n",
    "    # Chaque flow a un identifiant unique\n",
    "    flow_id = flow.get(\"flow_id\")\n",
    "    \n",
    "    # Vérifie si ce flow correspond à une alerte\n",
    "    # → permet de labelliser normal vs anomalie\n",
    "    is_anomaly = any(alert.get(\"flow_id\") == flow_id for alert in alerts)\n",
    "    \n",
    "    # Extraction des features\n",
    "    features = {\n",
    "        \n",
    "        # --- Métriques réseau brutes ---\n",
    "        \"pkts_toserver\": flow_data.get(\"pkts_toserver\", 0),\n",
    "        \"pkts_toclient\": flow_data.get(\"pkts_toclient\", 0),\n",
    "        \"bytes_toserver\": flow_data.get(\"bytes_toserver\", 0),\n",
    "        \"bytes_toclient\": flow_data.get(\"bytes_toclient\", 0),\n",
    "        \n",
    "        # --- Totaux (features dérivées simples) ---\n",
    "        \"total_pkts\": flow_data.get(\"pkts_toserver\", 0) + flow_data.get(\"pkts_toclient\", 0),\n",
    "        \"total_bytes\": flow_data.get(\"bytes_toserver\", 0) + flow_data.get(\"bytes_toclient\", 0),\n",
    "        \n",
    "        # --- Informations réseau ---\n",
    "        \"src_port\": flow.get(\"src_port\", 0),\n",
    "        \"dest_port\": flow.get(\"dest_port\", 0),\n",
    "        \n",
    "        # Encodage numérique du protocole :\n",
    "        # TCP → 6\n",
    "        # UDP → 17\n",
    "        # Autre → 0\n",
    "        \"proto\": 6 if flow.get(\"proto\") == \"TCP\" else 17 if flow.get(\"proto\") == \"UDP\" else 0,\n",
    "        \n",
    "        # --- Label ML ---\n",
    "        \"is_anomaly\": 1 if is_anomaly else 0,  # 1 = attaque, 0 = normal\n",
    "        \"attack_type\": \"normal\"                # type d'attaque (si anomalie)\n",
    "    }\n",
    "    \n",
    "    # Si anomalie → récupérer signature exacte\n",
    "    if is_anomaly:\n",
    "        for alert in alerts:\n",
    "            if alert.get(\"flow_id\") == flow_id:\n",
    "                # Récupère la signature de l'alerte\n",
    "                signature = alert.get(\"alert\", {}).get(\"signature\", \"unknown\")\n",
    "                features[\"attack_type\"] = signature\n",
    "                break  # on s'arrête à la première correspondance\n",
    "    \n",
    "    # Ajout de la ligne au dataset\n",
    "    data.append(features)\n",
    "\n",
    "# Création du DataFrame pandas à partir de la liste de dictionnaires\n",
    "df = pd.DataFrame(data)\n",
