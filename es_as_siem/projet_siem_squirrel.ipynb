    "alert http any any -> any any (msg:\"BRUTE FORCE DETECTED\"; content:\"pass=\"; http_uri; threshold:type both, track by_src, count 6, seconds 10; sid:5000003; rev:1;)\n",
    "\"\"\"\n",
    "\n",
    "\n",
    "# Créer le fichier local contenant les règles\n",
