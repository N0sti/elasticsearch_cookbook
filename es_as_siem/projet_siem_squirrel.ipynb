    "def simulate_brute_force(src_ip=\"192.168.99.3\", target_ip=\"10.0.0.5\", num_attempts=200):\n",
    "    \"\"\"\n",
    "    Simule une attaque par brute-force SSH : une même IP source envoie de\n",
    "    nombreuses tentatives de connexion vers le port 22 d'une cible en peu\n",
    "    de temps — comportement typique d'outils comme Hydra ou Medusa.\n",
    "    \"\"\"\n",
    "    index = get_or_create_index()\n",
    "    now = datetime.now(timezone.utc)\n",
    "    docs = []\n",
    "    bf_signatures = [\n",
    "        (2001219, \"ET SCAN SSH BruteForce Tool\"),\n",
    "        (2010937, \"ET SCAN Potential SSH Scan OUTBOUND\"),\n",
    "        (2003068, \"ET SCAN Rapid SSH Attempt\"),\n",
    "    ]\n",
    "    for i in range(num_attempts):\n",
    "        sig_id, sig_name = random.choice(bf_signatures)\n",
    "        docs.append({\n",
    "            \"@timestamp\": (now - timedelta(seconds=i * 1.5)).isoformat(),\n",
    "            \"event_type\": \"alert\",\n",
    "            \"src_ip\": src_ip,\n",
    "            \"src_port\": random.randint(40000, 60000),\n",
    "            \"dest_ip\": target_ip,\n",
    "            \"dest_port\": 22,\n",
    "            \"proto\": \"TCP\",\n",
    "            \"alert\": {\n",
    "                \"signature_id\": sig_id,\n",
    "                \"signature\": sig_name,\n",
    "                \"category\": \"Attempted Information Leak\",\n",
    "                \"severity\": 2,\n",
    "            },\n",
    "            \"simulation\": True,\n",
    "        })\n",
    "\n",
    "    helpers.bulk(es, [{\"_op_type\": \"create\", \"_index\": index, \"_source\": d} for d in docs])\n",
    "    es.indices.refresh(index=index)\n",
    "    print(f\"   {num_attempts} tentatives brute-force SSH injectées depuis {src_ip}\")\n",
    "    print(f\"   Cible : {target_ip}:22 | Index : {index}\")\n",
    "\n",
    "\n",
    "simulate_brute_force(src_ip=\"192.168.99.3\", target_ip=\"10.0.0.5\", num_attempts=200)"
   ]
