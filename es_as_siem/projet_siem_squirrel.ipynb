    "\"\"\"\n",
    "═══════════════════════════════════════════════════════════\n",
    "CELLULE : CLASSIFICATION MULTI-CLASSES DES ATTAQUES (ML AVANCÉ)\n",
    "═══════════════════════════════════════════════════════════\n",
    "Cette cellule entraîne un modèle supervisé capable de classifier\n",
    "les connexions réseau en plusieurs types d’attaques.\n",
    "\"\"\"\n",
    "\n",
    "# IMPORTS========================\n",
    "\n",
    "# Manipulation de données\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "# Modèle de classification\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "# Encodage des labels texte → numérique\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "# Séparation train/test\n",
    "from sklearn.model_selection import train_test_split\n",
    "# Métriques d’évaluation\n",
    "from sklearn.metrics import classification_report, confusion_matrix\n",
    "# Visualisation\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "\n",
    "print(\"CLASSIFICATION MULTI-CLASSES DES TYPES D'ATTAQUES\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "# PRÉPARATION DES DONNÉES==========\n",
    "\n",
    "print(\"\\n[1] Extraction des types d'attaques...\")\n",
    "\n",
    "# Dictionnaire qui mappe les signatures Suricata\n",
    "# vers des catégories d’attaques simplifiées\n",
    "attack_categories = {    \n",
    "    # Attaques par force brute\n",
    "    'Brute Force': 'BRUTE_FORCE',\n",
    "    'Login Attempt': 'BRUTE_FORCE',\n",
    "    # Scan de ports\n",
    "    'Port Scan': 'PORT_SCAN',\n",
    "    'SYN Scan': 'PORT_SCAN',\n",
    "    # Outils de scan\n",
    "    'Scanner': 'SCANNER',\n",
    "    'Nmap': 'SCANNER',\n",
    "    # Trafic normal\n",
    "    'HTTP Traffic': 'NORMAL',\n",
    "}\n",
    "\n",
    "def categorize_attack(signature):\n",
    "    \"\"\"\n",
    "    Convertit une signature Suricata brute\n",
    "    en catégorie d’attaque standardisée.\n",
    "    \"\"\"\n",
    "    if not signature or signature == 'normal':\n",
    "        return 'NORMAL'\n",
    "    \n",
    "    # Recherche par correspondance partielle\n",
    "    for pattern, category in attack_categories.items():\n",
    "        if pattern.lower() in signature.lower():\n",
    "            return category\n",
    "    \n",
    "    # Si aucune correspondance trouvée\n",
    "    return 'OTHER'\n",
    "\n",
    "\n",
    "# Création d'une nouvelle colonne catégorisée\n",
    "df['attack_category'] = df['attack_type'].apply(categorize_attack)\n",
    "\n",
    "print(f\"✓ {len(df)} échantillons catégorisés\")\n",
    "\n",
    "# Affichage de la distribution des classes\n",
    "category_counts = df['attack_category'].value_counts()\n",
    "for category, count in category_counts.items():\n",
    "    print(f\"   • {category:20s} : {count:5d} ({count/len(df)*100:.1f}%)\")\n",
    "\n",
    "\n",
    "# ENCODAGE DES LABELS==================\n",
    "\n",
    "print(f\"\\n[2] Encodage des labels...\")\n",
    "\n",
    "# Les modèles ML ne comprennent pas le texte.\n",
    "# On transforme les catégories en entiers.\n",
    "label_encoder = LabelEncoder()\n",
    "y_multi = label_encoder.fit_transform(df['attack_category'])\n",
    "\n",
    "print(f\"✓ {len(label_encoder.classes_)} classes encodées\")\n",
    "print(f\"   Classes : {', '.join(label_encoder.classes_)}\")\n",
    "\n",
    "\n",
    "# SÉLECTION DES FEATURES================\n",
    "\n",
    "print(f\"\\n[3] Sélection des features...\")\n",
    "\n",
    "# On reprend les features utilisées précédemment\n",
    "X_multi = df[feature_columns].copy()\n",
    "\n",
    "# Ajout de nouvelles features dérivées\n",
    "# → améliore la capacité du modèle à différencier les attaques\n",
    "\n",
    "# Volume global de trafic\n",
    "X_multi['total_traffic'] = X_multi['total_pkts'] * X_multi['total_bytes']\n",
    "\n",
    "# Indique si le port est > 1024 (souvent dynamique)\n",
    "X_multi['is_high_port'] = (X_multi['dest_port'] > 1024).astype(int)\n",
    "\n",
    "# Indique si trafic web classique (80 ou 443)\n",
    "X_multi['is_web_port'] = (\n",
    "    (X_multi['dest_port'] == 80) |\n",
    "    (X_multi['dest_port'] == 443)\n",
    ").astype(int)\n",
    "\n",
    "# Nettoyage des valeurs infinies ou manquantes\n",
    "X_multi = X_multi.replace([np.inf, -np.inf], np.nan).fillna(0)\n",
    "\n",
    "\n",
    "# SPLIT TRAIN / TEST======================\n",
    "\n",
    "print(f\"\\n[4] Split train/test...\")\n",
    "\n",
    "# Séparation des données (70% train / 30% test)\n",
    "# stratify=y_multi permet de garder la proportion des classes\n",
    "X_train_multi, X_test_multi, y_train_multi, y_test_multi = train_test_split(\n",
    "    X_multi, y_multi,\n",
    "    test_size=0.3,\n",
    "    random_state=42,\n",
    "    stratify=y_multi\n",
    ")\n",
    "\n",
    "# Normalisation (important pour stabilité du modèle)\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "scaler_multi = StandardScaler()\n",
    "\n",
    "X_train_multi_scaled = scaler_multi.fit_transform(X_train_multi)\n",
    "X_test_multi_scaled = scaler_multi.transform(X_test_multi)\n",
    "\n",
    "\n",
    "# ENTRAÎNEMENT DU RANDOM FOREST===========\n",
    "\n",
    "print(f\"\\n[5] Entraînement du Random Forest Classifier...\")\n",
    "\n",
    "rf_classifier = RandomForestClassifier(\n",
    "    n_estimators=100,        # Nombre d’arbres\n",
    "    max_depth=15,            # Profondeur max des arbres\n",
    "    random_state=42,\n",
    "    n_jobs=-1,               # Utilise tous les CPU\n",
    "    class_weight='balanced'  # Corrige déséquilibre des classes\n",
    ")\n",
    "# Apprentissage\n",
    "rf_classifier.fit(X_train_multi_scaled, y_train_multi)\n",
    "\n",
    "\n",
    "# PRÉDICTIONS===========================\n",
    "\n",
    "y_pred_multi = rf_classifier.predict(X_test_multi_scaled)\n",
    "\n",
    "# Probabilités associées à chaque classe\n",
    "y_pred_proba = rf_classifier.predict_proba(X_test_multi_scaled)\n",
    "\n",
    "\n",
    "# ÉVALUATION DU MODÈLE==================\n",
    "\n",
    "from sklearn.metrics import accuracy_score\n",
    "print(\"==================================================\\n MÉTRIQUES DE PERFORMANCE\")\n",
    "accuracy_multi = accuracy_score(y_test_multi, y_pred_multi)\n",
    "\n",
    "print(f\"\\n Accuracy globale : {accuracy_multi:.3f}\")\n",
    "\n",
    "# Rapport détaillé :\n",
    "# précision, recall, F1-score par classe\n",
    "print(classification_report(\n",
    "    y_test_multi,\n",
    "    y_pred_multi,\n",
    "    target_names=label_encoder.classes_,\n",
    "    zero_division=0\n",
    "))\n",
    "\n",
    "print(\"==============================================\")\n",
    "# MATRICE DE CONFUSION==================\n",
    "\n",
    "cm = confusion_matrix(y_test_multi, y_pred_multi)\n",
    "\n",
    "# Visualisation heatmap\n",
    "plt.figure(figsize=(12, 10))\n",
    "sns.heatmap(\n",
    "    cm,\n",
    "    annot=True,\n",
    "    fmt='d',\n",
    "    cmap='Blues',\n",
    "    xticklabels=label_encoder.classes_,\n",
    "    yticklabels=label_encoder.classes_\n",
    ")\n",
    "\n",
    "plt.title('Matrice de Confusion - Classification Multi-Classes')\n",
    "plt.ylabel('Vraie Classe')\n",
    "plt.xlabel('Classe Prédite')\n",
    "plt.tight_layout()\n",
    "plt.savefig('confusion_matrix_multiclass.png')\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# IMPORTANCE DES FEATURES======================\n",
    "\n",
    "# Analyse quelles va,riables influencent le plus la décision\n",
    "feature_importance = pd.DataFrame({\n",
    "    'feature': X_multi.columns,\n",
    "    'importance': rf_classifier.feature_importances_\n",
    "}).sort_values('importance', ascending=False)\n",
    "\n",
    "# Affiche les 10 plus importantes\n",
    "print(\"\\n📊 Top 10 features les plus importantes :\")\n",
    "print(feature_importance.head(10))\n",
    "\n",
    "\n",
    "# SAUVEGARDE DU MODÈLE========================\n",
    "\n",
    "import pickle\n",
    "\n",
    "# On sauvegarde tout le pipeline nécessaire à la prédiction\n",
    "model_package_multi = {\n",
    "    \"model\": rf_classifier,\n",
    "    \"scaler\": scaler_multi,\n",
    "    \"label_encoder\": label_encoder,\n",
    "    \"feature_columns\": list(X_multi.columns),\n",
    "    \"accuracy\": accuracy_multi\n",
    "}\n",
    "\n",
    "with open('attack_classifier_multiclass.pkl', 'wb') as f:\n",
    "    pickle.dump(model_package_multi, f)\n",
    "\n",
    "print(\"✓ Modèle sauvegardé : attack_classifier_multiclass.pkl\")"
