    "import requests as http_requests\n",
    "\n",
    "KIBANA_USER = ES_USER\n",
    "KIBANA_PASS = ES_PASSWORD\n",
    "HEADERS = {\n",
    "    \"kbn-xsrf\": \"true\",\n",
    "    \"Content-Type\": \"application/json\",\n",
    "}\n",
    "AUTH = (KIBANA_USER, KIBANA_PASS)\n",
    "\n",
    "\n",
    "def kibana_post(path, body):\n",
    "    \"\"\"Helper pour les appels à l'API Kibana.\"\"\"\n",
    "    resp = http_requests.post(\n",
    "        f\"{KIBANA_HOST}{path}\", headers=HEADERS, auth=AUTH, json=body, verify=False\n",
    "    )\n",
    "    if resp.status_code not in (200, 201):\n",
    "        print(f\"  ⚠️  {path} → {resp.status_code}: {resp.text[:200]}\")\n",
    "        return None\n",
    "    return resp.json()\n",
    "\n",
    "\n",
    "# ── 1. Index pattern suricata-* ──────────────────────────────\n",
    "ip_resp = kibana_post(\"/api/saved_objects/index-pattern/suricata-pattern\", {\n",
    "    \"attributes\": {\n",
    "        \"title\": \"suricata-*\",\n",
    "        \"timeFieldName\": \"@timestamp\",\n",
    "    }\n",
    "})\n",
    "if ip_resp:\n",
    "    print(\"✅ Index pattern 'suricata-*' créé\")\n",
    "\n",
