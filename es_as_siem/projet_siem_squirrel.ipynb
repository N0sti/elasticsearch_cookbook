    "import subprocess  # Permet d'exécuter des commandes système (docker, curl, etc.)\n",
    "import time        # Permet de gérer les temporisations et mesurer le temps\n",
    "\n",
    "print(\"💥 ATTAQUE : HTTP BURST\")\n",
    "print(\"=\" * 60)\n",
    "print(\"\\n📋 Objectif : Déclencher 'HTTP BURST DETECTED'\")\n",
    "print(\"   Règle : 15 requêtes HTTP en 2 secondes\\n\")\n",
    "\n",
    "# Récupération de l'IP Docker du container Suricata\n",
    "\n",
    "print(\"🔎 Récupération IP Docker du container suricata...\")\n",
    "result = subprocess.run(\n",
    "    [\"docker\", \"inspect\", \"-f\",\n",
    "     \"{{range.NetworkSettings.Networks}}{{.IPAddress}}{{end}}\",\n",
    "     \"suricata\"],\n",
    "    capture_output=True,  # Capture la sortie de la commande\n",
    "    text=True             # Retourne la sortie en texte\n",
    ")\n",
    "\n",
    "# Récupère l'adresse IP et supprime les espaces / retours ligne\n",
    "target_ip = result.stdout.strip()\n",
    "\n",
    "# Vérifie si une IP a bien été récupérée\n",
    "if not target_ip:\n",
    "    print(\"❌ Impossible de récupérer l'IP Docker\")\n",
    "    exit()  # Arrêt du script si échec\n",
    "\n",
    "print(f\"   IP container : {target_ip}\")\n",
    "\n",
    "# Démarrage d'un serveur HTTP dans le container\n",
    "\n",
    "print(\"\\nDémarrage d'un serveur HTTP (port 8080) dans le container...\")\n",
    "\n",
    "# Lance un serveur HTTP Python en arrière-plan (-d = detached)\n",
    "# Utilise le port 8080 pour éviter conflits\n",
    "server = subprocess.Popen(\n",
    "    [\"docker\", \"exec\", \"-d\", \"suricata\",\n",
    "     \"python3\", \"-m\", \"http.server\", \"8080\"],\n",
    "    stdout=subprocess.DEVNULL,  # Ignore la sortie standard\n",
    "    stderr=subprocess.DEVNULL   # Ignore les erreurs\n",
    ")\n",
    "\n",
    "# Laisse le temps au serveur de démarrer correctement\n",
    "time.sleep(2)\n",
    "print(\"  Serveur HTTP prêt sur le port 8080\")\n",
    "\n",
    "# Construit l'URL cible\n",
    "target = f\"http://{target_ip}:8080\"\n",
    "print(f\"   Cible : {target}\")\n",
    "\n",
    "# Envoi d'un burst HTTP\n",
    "\n",
    "num_requests = 20  # Nombre de requêtes > seuil de 15\n",
    "\n",
    "print(f\"\\n  Envoi de {num_requests} requêtes HTTP...\\n\")\n",
    "\n",
    "start = time.time()  # Début du chronométrage\n",
    "\n",
    "# Boucle d'envoi des requêtes HTTP\n",
    "for i in range(1, num_requests + 1):\n",
    "\n",
    "    # Envoie une requête HTTP avec curl\n",
    "    subprocess.run(\n",
    "        [\"curl\", \"-s\", \"-o\", \"/dev/null\",  # Mode silencieux, ignore la sortie\n",
    "         \"--max-time\", \"1\",               # Timeout max 1 seconde\n",
    "         target],\n",
    "        capture_output=True,  # Capture la sortie\n",
    "        timeout=2             # Timeout global de sécurité\n",
    "    )\n",
    "\n",
    "    # Affiche une progression toutes les 5 requêtes\n",
    "    if i % 5 == 0:\n",
    "        print(f\"  [{i:2d}/{num_requests}] Requêtes envoyées\")\n",
    "\n",
    "    # Pause de 70 ms entre requêtes (~14 requêtes/seconde)\n",
    "    time.sleep(0.07)\n",
    "\n",
    "# Calcul du temps total\n",
    "duration = time.time() - start\n",
    "\n",
    "print(f\"\\n✅ {num_requests} requêtes HTTP en {duration:.2f} secondes\")\n",
    "print(f\"   Taux    : {num_requests/duration:.1f} requêtes/seconde\")\n",
    "print(f\"   Seuil   : 15 requêtes en 2s → {num_requests} en {duration:.2f}s\")\n",
    "print(\"\\nDevrait déclencher : HTTP BURST DETECTED (sid:5000002)\")\n",
    "\n",
    "# Arrêt du serveur HTTP\n",
    "\n",
    "print(\"\\n Arrêt du serveur HTTP...\")\n",
    "\n",
    "# Tue le processus http.server dans le container\n",
    "subprocess.run(\n",
    "    [\"docker\", \"exec\", \"suricata\",\n",
    "     \"pkill\", \"-f\", \"http.server\"],\n",
    "    capture_output=True\n",
    ")\n",
    "\n",
    "# Vérification des alertes dans eve.json\n",
    "\n",
    "print(\"\\n⏳ Attente 1s pour que Suricata écrive les alertes...\")\n",
    "time.sleep(1)  # Laisse le temps à Suricata d'écrire les logs\n",
    "\n",
    "import json  # Importé mais non utilisé dans ce script\n",
    "\n",
    "print(\"\\n🔍 Recherche de l'alerte HTTP BURST dans eve.json :\")\n",
    "\n",
    "# Recherche de la chaîne \"HTTP BURST DETECTED\" dans les logs\n",
    "grep_result = subprocess.run(\n",
    "    [\"docker\", \"exec\", \"suricata\",\n",
    "     \"grep\", \"HTTP BURST DETECTED\",\n",
    "     \"/var/log/suricata/eve.json\"],\n",
    "    capture_output=True, text=True\n",
    ")\n",
    "\n",
    "# Vérifie si des alertes ont été trouvées\n",
    "if grep_result.stdout:\n",
    "    lines = grep_result.stdout.strip().split(\"\\n\")\n",
    "    print(f\"   {len(lines)} alerte(s) HTTP BURST trouvée(s) !\\n\")\n",
    "    for line in lines:\n",
    "        print(line)\n",
    "else:\n",
