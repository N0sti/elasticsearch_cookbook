    "\n",
    "\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "# A. ISOLATION FOREST  (sklearn)\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "\n",
    "from sklearn.ensemble import IsolationForest\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "def fetch_features(index=\"suricata-*\", size=10000):\n",
    "    \"\"\"Récupère les données Suricata et construit un DataFrame de features par IP.\"\"\"\n",
    "    result = es.search(index=index, body={\n",
    "        \"size\": size,\n",
    "        \"query\": {\"match_all\": {}},\n",
    "        \"_source\": [\"src_ip\", \"event_type\", \"dest_ip\", \"dest_port\",\n",
    "                    \"alert.signature_id\", \"alert.severity\", \"flow.bytes_toserver\"],\n",
    "    })\n",
    "\n",
    "    rows = []\n",
    "    for hit in result[\"hits\"][\"hits\"]:\n",
    "        s = hit[\"_source\"]\n",
    "        rows.append({\n",
    "            \"src_ip\":       s.get(\"src_ip\", \"unknown\"),\n",
    "            \"event_type\":   s.get(\"event_type\", \"other\"),\n",
    "            \"dest_ip\":      s.get(\"dest_ip\", \"\"),\n",
    "            \"dest_port\":    s.get(\"dest_port\", 0),\n",
    "            \"sig_id\":       s.get(\"alert\", {}).get(\"signature_id\", 0),\n",
    "            \"severity\":     s.get(\"alert\", {}).get(\"severity\", 0),\n",
    "            \"bytes_out\":    s.get(\"flow\", {}).get(\"bytes_toserver\", 0),\n",
    "        })\n",
    "\n",
    "    df = pd.DataFrame(rows)\n",
    "    if df.empty:\n",
    "        raise ValueError(\"Aucune donnée trouvée dans l'index suricata-*\")\n",
    "\n",
    "    # Feature engineering par IP source\n",
    "    features = df.groupby(\"src_ip\").agg(\n",
    "        n_events       =(\"event_type\", \"count\"),\n",
    "        n_alerts       =(\"event_type\", lambda x: (x == \"alert\").sum()),\n",
    "        n_http         =(\"event_type\", lambda x: (x == \"http\").sum()),\n",
    "        n_flows        =(\"event_type\", lambda x: (x == \"flow\").sum()),\n",
    "        n_unique_sigs  =(\"sig_id\",     \"nunique\"),\n",
    "        n_unique_dests =(\"dest_ip\",    \"nunique\"),\n",
    "        n_unique_ports =(\"dest_port\",  \"nunique\"),\n",
    "        max_severity   =(\"severity\",   \"max\"),\n",
    "        total_bytes_out=(\"bytes_out\",  \"sum\"),\n",
    "        mean_bytes_out =(\"bytes_out\",  \"mean\"),\n",
    "    ).reset_index()\n",
    "\n",
    "    return features\n",
    "\n",
    "\n",
    "features = fetch_features()\n",
    "print(f\"📊 {len(features)} IPs sources analysées\")\n",
    "print(features.describe())\n",
    "\n",
    "# Isolation Forest\n",
    "X = features.drop(columns=[\"src_ip\"]).fillna(0)\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(X)\n",
    "\n",
    "iso_forest = IsolationForest(contamination=0.1, random_state=42, n_estimators=200)\n",
    "features[\"anomaly_score\"] = iso_forest.fit_predict(X_scaled)\n",
    "features[\"raw_score\"]     = iso_forest.score_samples(X_scaled)\n",
    "\n",
    "anomalous = features[features[\"anomaly_score\"] == -1].sort_values(\"raw_score\")\n",
    "normal    = features[features[\"anomaly_score\"] ==  1]\n",
    "\n",
    "print(f\"\\n🚨 IPs anormales détectées : {len(anomalous)} / {len(features)}\")\n",
    "print(anomalous[[\"src_ip\", \"n_events\", \"n_alerts\", \"n_unique_sigs\",\n",
    "                  \"n_unique_dests\", \"total_bytes_out\", \"raw_score\"]].to_string())\n",
    "\n",
    "# Visualisation — scatter plot score vs events\n",
    "fig = px.scatter(\n",
    "    features,\n",
    "    x=\"n_events\",\n",
    "    y=\"raw_score\",\n",
    "    color=features[\"anomaly_score\"].map({1: \"Normal\", -1: \"Anomalie\"}),\n",
    "    hover_data=[\"src_ip\", \"n_unique_sigs\", \"n_unique_dests\", \"total_bytes_out\"],\n",
    "    title=\"Isolation Forest — Score d'anomalie par IP source\",\n",
    "    labels={\"n_events\": \"Nombre d'événements\", \"raw_score\": \"Score (plus bas = plus anormal)\"},\n",
    "    color_discrete_map={\"Normal\": \"#2196F3\", \"Anomalie\": \"#F44336\"},\n",
    ")\n",
    "fig.show()\n",
    "\n",
    "# Radar chart des IPs anormales\n",
    "if not anomalous.empty:\n",
    "    top_anomalous = anomalous.head(5)\n",
    "    cols = [\"n_unique_sigs\", \"n_unique_dests\", \"n_unique_ports\", \"max_severity\",\n",
    "            \"n_http\", \"n_flows\"]\n",
    "    norm = top_anomalous[cols].div(top_anomalous[cols].max()).fillna(0)\n",
    "\n",
    "    fig2 = go.Figure()\n",
    "    for _, row in top_anomalous.iterrows():\n",
    "        values = [norm.loc[row.name, c] for c in cols]\n",
    "        fig2.add_trace(go.Scatterpolar(\n",
    "            r=values + [values[0]],\n",
    "            theta=cols + [cols[0]],\n",
    "            name=row[\"src_ip\"],\n",
    "            fill=\"toself\",\n",
    "        ))\n",
    "    fig2.update_layout(\n",
    "        polar=dict(radialaxis=dict(visible=True, range=[0, 1])),\n",
    "        title=\"Profil des IPs anormales (radar)\",\n",
    "    )\n",
    "    fig2.show()"
   ]
  },
