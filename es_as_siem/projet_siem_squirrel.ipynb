    "            \"proto\": \"TCP\",\n",
    "            \"alert\": {\n",
    "                \"signature_id\": sig_id,\n",
    "                \"signature\": sig_name,\n",
    "                \"category\": \"Attempted Information Leak\",\n",
    "                \"severity\": 2,\n",
    "            },\n",
    "            \"simulation\": True,\n",
    "        })\n",
