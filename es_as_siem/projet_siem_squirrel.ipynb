    "def simulate_data_exfiltration(src_ip=\"10.0.0.20\", num_flows=50):\n",
    "    \"\"\"\n",
    "    Simule une exfiltration de données : une machine interne envoie de gros\n",
    "    volumes de données vers des IPs externes inhabituelles (C2 / data leak).\n",
    "    \"\"\"\n",
    "    index = get_or_create_index()\n",
    "    now = datetime.now(timezone.utc)\n",
    "    docs = []\n",
    "    # IPs externes \"suspectes\" (plages réservées aux exemples RFC5737)\n",
    "    external_ips = [f\"198.51.100.{i}\" for i in range(10, 30)]\n",
    "\n",
    "    for i in range(num_flows):\n",
    "        ts = now - timedelta(minutes=i * 2)\n",
    "        bytes_out = random.randint(500_000, 50_000_000)  # 500 KB → 50 MB\n",
    "        docs.append({\n",
    "            \"@timestamp\": ts.isoformat(),\n",
    "            \"event_type\": \"flow\",\n",
    "            \"src_ip\": src_ip,\n",
    "            \"src_port\": random.randint(40000, 60000),\n",
    "            \"dest_ip\": random.choice(external_ips),\n",
    "            \"dest_port\": random.choice([443, 80, 8443, 4444]),\n",
    "            \"proto\": \"TCP\",\n",
    "            \"flow\": {\n",
    "                \"pkts_toserver\": random.randint(100, 500),\n",
    "                \"pkts_toclient\": random.randint(10, 50),\n",
    "                \"bytes_toserver\": bytes_out,\n",
    "                \"bytes_toclient\": random.randint(1000, 10000),\n",
    "                \"state\": \"closed\",\n",
    "                \"reason\": \"timeout\",\n",
    "            },\n",
    "            \"alert\": {\n",
    "                \"signature_id\": 2030359,\n",
    "                \"signature\": \"ET POLICY Large Outbound Transfer Detected\",\n",
    "                \"category\": \"Potential Corporate Privacy Violation\",\n",
    "                \"severity\": 2,\n",
    "            },\n",
    "            \"simulation\": True,\n",
    "        })\n",
    "\n",
    "    helpers.bulk(es, [{\"_op_type\": \"create\", \"_index\": index, \"_source\": d} for d in docs])\n",
    "    es.indices.refresh(index=index)\n",
    "    total_mb = sum(d[\"flow\"][\"bytes_toserver\"] for d in docs) / 1e6\n",
    "    print(f\"   {num_flows} flux d'exfiltration injectés depuis {src_ip}\")\n",
    "    print(f\"   Volume total simulé : {total_mb:.1f} MB → {len(set(d['dest_ip'] for d in docs))} IPs externes\")\n",
    "\n",
    "\n",
    "simulate_data_exfiltration(src_ip=\"10.0.0.20\", num_flows=50)"
   ]
