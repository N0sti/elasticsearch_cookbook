    "        (2010935, \"ET SCAN Potential SSH Scan\"),\n",
    "        (2001219, \"ET SCAN Potential VNC Scan\"),\n",
    "        (2010937, \"ET SCAN Potential FTP Scan\"),\n",
    "        (2010585, \"ET SCAN NMAP -sV\"),\n",
    "        (2000368, \"ET SCAN Suspicious inbound to MSSQL port 1433\"),\n",
    "    ]\n",
    "    for i in range(num_events):\n",
    "        sig_id, sig_name = random.choice(scan_signatures)\n",
    "        docs.append({\n",
