    "def detect_anomalies_basic(index=None):\n",
    "    \"\"\"\n",
    "    Détecte des comportements anormaux à partir de règles basées sur des seuils.\n",
    "    Couvre : scan de ports, burst HTTP, brute-force SSH, exfiltration.\n",
    "    \"\"\"\n",
    "    if index is None:\n",
    "        index = f\"suricata-{datetime.now(timezone.utc).strftime('%Y.%m.%d')}\"\n",
    "\n",
    "    anomalies = []\n",
    "    print(\"=\" * 60)\n",
    "    print(\"  Détection d'anomalies — règles basiques\")\n",
    "    print(\"=\" * 60)\n",
    "\n",
    "    # ── 1. Scan de ports ────────────────────────────────────────\n",
    "    result = es.search(index=index, body={\n",
    "        \"size\": 0,\n",
    "        \"query\": {\"term\": {\"event_type\": \"alert\"}},\n",
    "        \"aggs\": {\n",
    "            \"per_src\": {\n",
    "                \"terms\": {\"field\": \"src_ip\", \"size\": 20},\n",
    "                \"aggs\": {\n",
    "                    \"unique_sigs\":  {\"cardinality\": {\"field\": \"alert.signature_id\"}},\n",
    "                    \"unique_dests\": {\"cardinality\": {\"field\": \"dest_ip\"}},\n",
    "                    \"unique_ports\": {\"cardinality\": {\"field\": \"dest_port\"}},\n",
    "                    \"total\":        {\"value_count\":  {\"field\": \"event_type\"}},\n",
    "                }\n",
    "            }\n",
    "        }\n",
    "    })\n",
    "    print(\"\\nScan de ports (>3 signatures uniques OU >5 destinations)\")\n",
    "    for bucket in result[\"aggregations\"][\"per_src\"][\"buckets\"]:\n",
    "        ip     = bucket[\"key\"]\n",
    "        sigs   = bucket[\"unique_sigs\"][\"value\"]\n",
    "        dests  = bucket[\"unique_dests\"][\"value\"]\n",
    "        ports  = bucket[\"unique_ports\"][\"value\"]\n",
    "        total  = bucket[\"total\"][\"value\"]\n",
    "        if sigs > 3 or dests > 5:\n",
    "            anomalies.append({\"ip\": ip, \"type\": \"Port Scan\", \"sigs\": sigs, \"dests\": dests, \"total\": total})\n",
    "            print(f\"  🚨 {ip:20s}  sigs={sigs:3d}  dests={dests:3d}  ports={ports:4d}  total={total}\")\n",
    "\n",
    "    # ── 2. Burst HTTP (>50 events en 60 s depuis même IP) ───────\n",
    "    result = es.search(index=index, body={\n",
    "        \"size\": 0,\n",
    "        \"query\": {\"term\": {\"event_type\": \"http\"}},\n",
    "        \"aggs\": {\n",
    "            \"per_src\": {\n",
    "                \"terms\": {\"field\": \"src_ip\", \"size\": 20},\n",
    "                \"aggs\": {\n",
    "                    \"over_time\": {\n",
    "                        \"date_histogram\": {\"field\": \"@timestamp\", \"fixed_interval\": \"60s\"},\n",
    "                        \"aggs\": {\"req_count\": {\"value_count\": {\"field\": \"src_ip\"}}}\n",
    "                    }\n",
    "                }\n",
    "            }\n",
    "        }\n",
    "    })\n",
    "    print(\"\\n🔍 Burst HTTP (>50 req en 60 s)\")\n",
    "    for bucket in result[\"aggregations\"][\"per_src\"][\"buckets\"]:\n",
    "        ip = bucket[\"key\"]\n",
    "        for tb in bucket[\"over_time\"][\"buckets\"]:\n",
    "            count = tb[\"req_count\"][\"value\"]\n",
    "            if count > 50:\n",
    "                ts = tb[\"key_as_string\"]\n",
    "                anomalies.append({\"ip\": ip, \"type\": \"HTTP Burst\", \"count\": count, \"window\": ts})\n",
    "                print(f\"  🚨 {ip:20s}  {count:4d} req en 60s  à {ts}\")\n",
    "\n",
    "    # ── 3. Brute-force SSH (>20 alertes en 5 min depuis même IP) ─\n",
    "    result = es.search(index=index, body={\n",
    "        \"size\": 0,\n",
    "        \"query\": {\n",
    "            \"bool\": {\n",
    "                \"must\": [\n",
    "                    {\"term\": {\"event_type\": \"alert\"}},\n",
    "                    {\"term\": {\"dest_port\": 22}}\n",
    "                ]\n",
    "            }\n",
    "        },\n",
    "        \"aggs\": {\n",
    "            \"per_src\": {\n",
    "                \"terms\": {\"field\": \"src_ip\", \"size\": 20},\n",
    "                \"aggs\": {\n",
    "                    \"over_time\": {\n",
    "                        \"date_histogram\": {\"field\": \"@timestamp\", \"fixed_interval\": \"5m\"},\n",
    "                        \"aggs\": {\"count\": {\"value_count\": {\"field\": \"src_ip\"}}}\n",
    "                    }\n",
    "                }\n",
    "            }\n",
    "        }\n",
    "    })\n",
    "    print(\"\\n🔍 Brute-force SSH (>20 alertes port 22 en 5 min)\")\n",
    "    for bucket in result[\"aggregations\"][\"per_src\"][\"buckets\"]:\n",
    "        ip = bucket[\"key\"]\n",
    "        for tb in bucket[\"over_time\"][\"buckets\"]:\n",
    "            count = tb[\"count\"][\"value\"]\n",
    "            if count > 20:\n",
    "                ts = tb[\"key_as_string\"]\n",
    "                anomalies.append({\"ip\": ip, \"type\": \"SSH Brute Force\", \"count\": count, \"window\": ts})\n",
    "                print(f\"  🚨 {ip:20s}  {count:4d} tentatives en 5 min  à {ts}\")\n",
    "\n",
    "    # ── 4. Exfiltration (flux sortants > 10 MB) ─────────────────\n",
    "    result = es.search(index=index, body={\n",
    "        \"size\": 0,\n",
    "        \"query\": {\"term\": {\"event_type\": \"flow\"}},\n",
    "        \"aggs\": {\n",
    "            \"per_src\": {\n",
    "                \"terms\": {\"field\": \"src_ip\", \"size\": 20},\n",
    "                \"aggs\": {\"total_bytes\": {\"sum\": {\"field\": \"flow.bytes_toserver\"}}}\n",
    "            }\n",
    "        }\n",
    "    })\n",
    "    print(\"\\n🔍 Exfiltration de données (>10 MB sortants depuis même IP)\")\n",
    "    for bucket in result[\"aggregations\"][\"per_src\"][\"buckets\"]:\n",
    "        ip = bucket[\"key\"]\n",
    "        mb = bucket[\"total_bytes\"][\"value\"] / 1e6\n",
    "        if mb > 10:\n",
    "            anomalies.append({\"ip\": ip, \"type\": \"Data Exfiltration\", \"mb\": round(mb, 1)})\n",
    "            print(f\"  🚨 {ip:20s}  {mb:8.1f} MB sortants\")\n",
    "\n",
    "    print(f\"\\n{'=' * 60}\")\n",
    "    print(f\"  Total anomalies détectées : {len(anomalies)}\")\n",
    "    return anomalies\n",
    "\n",
    "\n",
    "anomalies = detect_anomalies_basic()\n",
    "\n",
    "# Visualisation\n",
    "if anomalies:\n",
    "    df_a = pd.DataFrame(anomalies)\n",
    "    counts = df_a[\"type\"].value_counts().reset_index()\n",
    "    counts.columns = [\"type\", \"count\"]\n",
    "    fig = px.bar(counts, x=\"type\", y=\"count\", color=\"type\",\n",
    "                 title=\"Anomalies détectées par type (règles basiques)\",\n",
    "                 labels={\"type\": \"Type d'anomalie\", \"count\": \"Nombre\"})\n",
    "    fig.show()"
=======
