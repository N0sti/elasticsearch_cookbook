# Test basique
alert http any any -> any any (msg:"HTTP Traffic"; sid:1000001; rev:1;)

# User-Agent suspect
alert http any any -> any any (msg:"SQLMap Tool"; content:"User-Agent: sqlmap"; nocase; sid:1000004; rev:1;)

# Test IDS
alert http any any -> any any (msg:"IDS Test"; content:"uid=0|28|root|29|"; sid:2100498; rev:7;)

# Port Scan
alert tcp any any -> any any (msg:"PORT SCAN DETECTED"; flags:S; threshold:type both, track by_src, count 10, seconds 10; sid:5000001; rev:1;)
alert tcp any any -> any any (msg:"PORT SCAN DETECTED - Permissive"; threshold:type both, track by_src, count 10, seconds 10; sid:7000001; rev:1;)
alert http any any -> any any (msg:"HTTP DETECTE"; sid:9999999; rev:1;)

# HTTP Burst
alert http any any -> any any (msg:"HTTP BURST DETECTED"; threshold:type both, track by_src, count 15, seconds 2; sid:5000002; rev:1;)

# Brute Force
alert http any any -> any any (msg:"BRUTE FORCE DETECTED"; content:"pass="; http_uri; threshold:type both, track by_src, count 6, seconds 10; sid:5000003; rev:1;)

# SQL Injection
alert http any any -> any any (msg:"WEB-SQLMAP detected"; flow:to_server,established; content:"sqlmap"; nocase; http_header; fast_pattern; sid:1000001; rev:1;)
alert http any any -> any any (msg:"WEB-SQLi attempt"; flow:to_server,established; content:"union select"; nocase; http_uri; fast_pattern; sid:1000002; rev:1;)

# LFI
alert http any any -> any any (msg:"WEB-LFI attempt"; flow:to_server,established; content:"../"; http_uri; nocase; sid:1000003; rev:1;)

# SSH
alert tcp any any -> any 22 (msg:"AUTH-SSH bruteforce"; flow:to_server,established; threshold:type threshold, track by_src, count 5, seconds 60; sid:3000001; rev:1;)
